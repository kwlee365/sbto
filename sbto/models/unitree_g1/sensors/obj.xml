<mujoco>
    <sensor>
        <!-- obj - floor  -->
        <contact geom1="obj" geom2="floor" reduce="maxforce" data="found force" num="1" name="obj_static_cnt"/>
        <!-- obj position and orientation  -->
        <framepos objtype="geom" objname="obj" name="global_pos_obj"/>
        <framequat objtype="geom" objname="obj" name="global_quat_obj"/>
        <!-- hands contact -->
        <contact geom1="obj" geom2="left_hand_collision" reduce="maxforce" data="found force" num="1" name="left_hand_cnt"/>
        <contact geom1="obj" geom2="right_hand_collision" reduce="maxforce" data="found force" num="1" name="right_hand_cnt"/>
    </sensor>
</mujoco>